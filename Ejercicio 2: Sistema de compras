class Producto:
    def __init__(self, nombre, precio, categoria):
        self.nombre = nombre
        self.precio = precio
        self.categoria = categoria

class Carrito:
    def __init__(self):
        self.lista_productos = []

    def agregar_producto(self, producto):
        self.lista_productos.append(producto)

    def eliminar_producto(self, nombre_producto):
        self.lista_productos = [p for p in self.lista_productos if p.nombre != nombre_producto]

    def calcular_total(self):
        total = sum(p.precio for p in self.lista_productos)
        return total

# Ejemplo de uso
p1 = Producto("Monitor", 250.0, "Electrónica")
p2 = Producto("Mouse", 25.0, "Periféricos")

mi_carrito = Carrito()
mi_carrito.agregar_producto(p1)
mi_carrito.agregar_producto(p2)
print(f"Total a pagar: ${mi_carrito.calcular_total()}")
